# .redteam-ignore — AI-Red-Teaming-Engine 除外ルール
#
# このファイルを .redteam-ignore にリネームして使用してください。
# 空行とコメント（#以降）は無視されます。

# ─── ディレクトリ除外（末尾に / 必須）────────────────────────────────
tests/              # テスト用の意図的脆弱性ファイルを除外
vendor/
third_party/

# ─── ファイル glob パターン ─────────────────────────────────────────
*.generated.py      # 自動生成ファイル
*.pb.go             # protobuf 生成コード
migrations/*.py     # DBマイグレーション（意図的なSQL操作を含む）

# ─── Severity 単位の除外 ────────────────────────────────────────────
severity:Info       # Infoレベルはノイズが多いので除外

# ─── Category 単位の除外 ────────────────────────────────────────────
# category:CORS     # CORS設定は別途レビュー済みの場合はコメントアウトを外す

# ─── 既知の誤検知を fingerprint で固定除外 ──────────────────────────
# fingerprint:abc123de  # ISSUE-001: 内部ネットワーク限定の設計のため問題なし

# ─── SARIF ruleId 形式での除外 ──────────────────────────────────────
# rule:RTE-Logging-Low   # ログ不足のLow指摘は今回対象外
